# 勝間 voice stack 用 API キー (このファイルをコピーして .env に保存)

# ElevenLabs Scribe (V2 マニフェスト構成、4/27〜)
# 取得: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq (V1 旧構成 / V3 GPT 120B 比較用)
# 取得: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini (コーディング支援用、勝間が日々使用)
# 取得: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 環境変数として読み込む場合は PowerShell で以下:
# $env:ELEVENLABS_API_KEY = "..."
# $env:GROQ_API_KEY = "..."
# $env:GEMINI_API_KEY = "..."
#
# 永続化するなら setx:
# setx ELEVENLABS_API_KEY "..."
# setx GROQ_API_KEY "..."
